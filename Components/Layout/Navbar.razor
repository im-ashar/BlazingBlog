@using BlazingBlog.Data
@using BlazingBlog.Data.Models
@using BlazingBlog.Services
@using BlazingBlog.Components.Shared
@using Microsoft.AspNetCore.Identity
@inject NavigationManager NavigationManager
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject ICategoryService CategoryService

<nav class="fixed top-0 inset-x-0 z-40 backdrop-blur-md bg-base-100/80 border-b border-base-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-2 group">
            <span class="inline-flex items-center justify-center size-8 rounded-lg bg-primary text-primary-content font-bold text-sm">B</span>
            <span class="font-display text-lg font-semibold tracking-tight">Blazing<span class="text-primary">Blog</span></span>
        </a>

        <ul class="hidden lg:flex items-center gap-1">
            @foreach (var category in _categories)
            {
                <li>
                    <NavLink class="px-3 py-2 rounded-md text-sm font-medium text-base-content/70 hover:text-base-content hover:bg-base-200 transition-colors"
                             ActiveClass="!text-base-content !bg-base-200"
                             href="@(category.Slug + "-posts")">
                        @category.Name
                    </NavLink>
                </li>
            }
        </ul>

        <div class="flex items-center gap-2">
            <button type="button"
                    onclick="BlazingBlogTheme.toggle()"
                    aria-label="Toggle theme"
                    class="btn btn-ghost btn-sm btn-circle theme-toggle-btn">
                <span class="theme-toggle-light"><Icon Name="moon" Class="size-5" /></span>
                <span class="theme-toggle-dark"><Icon Name="sun" Class="size-5" /></span>
            </button>

            <AuthorizeView>
                <Authorized>
                    <div class="dropdown dropdown-end">
                        <label tabindex="0" class="btn btn-ghost btn-sm gap-2 normal-case">
                            <span class="inline-flex items-center justify-center size-7 rounded-full bg-base-200 text-base-content text-xs font-semibold">
                                @GetInitials(context.User.GetFullNameOfUser())
                            </span>
                            <span class="hidden sm:inline text-sm">@context.User.GetFullNameOfUser()</span>
                            <Icon Name="chevron-down" Class="size-4" />
                        </label>
                        <ul tabindex="0" class="dropdown-content menu menu-sm bg-base-100 border border-base-300 rounded-box shadow-lg mt-2 w-56 p-2 z-50">
                            <li><NavLink href="admin/dashboard">Dashboard</NavLink></li>
                            <li><NavLink href="admin/manage-posts">Manage Posts</NavLink></li>
                            <li><NavLink href="admin/manage-categories">Manage Categories</NavLink></li>
                            <li><NavLink href="admin/manage-subscribers">Subscribers</NavLink></li>
                            <li class="border-t border-base-300 mt-1 pt-1"><LogoutForm /></li>
                        </ul>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <NavLink href="account/login" class="btn btn-ghost btn-sm">Login</NavLink>
                    <NavLink href="account/register" class="btn btn-primary btn-sm">Get started</NavLink>
                </NotAuthorized>
            </AuthorizeView>

            <div class="dropdown dropdown-end lg:hidden">
                <label tabindex="0" class="btn btn-ghost btn-sm btn-circle">
                    <Icon Name="menu" Class="size-5" />
                </label>
                <ul tabindex="0" class="dropdown-content menu menu-sm bg-base-100 border border-base-300 rounded-box shadow-lg mt-2 w-56 p-2 z-50">
                    @foreach (var category in _categories)
                    {
                        <li><NavLink href="@(category.Slug + "-posts")">@category.Name</NavLink></li>
                    }
                </ul>
            </div>
        </div>
    </div>
</nav>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private Category[] _categories = [];
    private const int maxCategoriesToShowOnNavbar = 5;

    protected async override Task OnInitializedAsync()
    {
        if (HttpContext.User.Identity != null && HttpContext.User.Identity.IsAuthenticated)
        {
            var user = await UserManager.GetUserAsync(HttpContext.User);
            if (user != null)
            {
                var additionalClaims = new List<Claim> { new Claim(AppConstants.ClaimNames.FullName, user.FullName) };
                await SignInManager.SignInWithClaimsAsync(user, false, additionalClaims);
            }
        }
        await GetCategoriesToShowOnNavbar();
    }

    private async Task GetCategoriesToShowOnNavbar()
    {
        var categories = await CategoryService.GetCategoriesAsync();
        _categories = categories
                                .Where(c => c.ShowOnNavbar)
                                .Take(maxCategoriesToShowOnNavbar)
                                .ToArray();
        if (_categories.Length < maxCategoriesToShowOnNavbar)
        {
            _categories = [.. _categories, .. categories.Where(c => !c.ShowOnNavbar).Take(maxCategoriesToShowOnNavbar - _categories.Length).ToArray()];
        }
    }

    private static string GetInitials(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "U";
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..1].ToUpperInvariant();
        return (parts[0][..1] + parts[^1][..1]).ToUpperInvariant();
    }
}
