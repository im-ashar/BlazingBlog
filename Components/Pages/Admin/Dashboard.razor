@page "/admin/dashboard"
@using BlazingBlog.Components.Shared
@inject IBlogPostAdminService BlogPostAdminService
@inject ICategoryService CategoryService
@inject ISubscriberService SubscriberService

<PageTitle>Dashboard · BlazingBlog Admin</PageTitle>

<AdminHeader Title="Dashboard" Subtitle="An overview of your blog." />

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <div class="bg-base-100 border border-base-300 rounded-box p-6">
        <div class="flex items-center justify-between">
            <span class="text-xs uppercase tracking-wider font-semibold text-base-content/60">Posts</span>
            <span class="inline-flex size-9 items-center justify-center rounded-md bg-primary/10 text-primary">
                <Icon Name="file-text" Class="size-4" />
            </span>
        </div>
        <div class="mt-3 font-display text-3xl font-semibold tracking-tight">@_posts</div>
    </div>
    <div class="bg-base-100 border border-base-300 rounded-box p-6">
        <div class="flex items-center justify-between">
            <span class="text-xs uppercase tracking-wider font-semibold text-base-content/60">Categories</span>
            <span class="inline-flex size-9 items-center justify-center rounded-md bg-secondary/10 text-secondary">
                <Icon Name="tag" Class="size-4" />
            </span>
        </div>
        <div class="mt-3 font-display text-3xl font-semibold tracking-tight">@_categories</div>
    </div>
    <div class="bg-base-100 border border-base-300 rounded-box p-6">
        <div class="flex items-center justify-between">
            <span class="text-xs uppercase tracking-wider font-semibold text-base-content/60">Subscribers</span>
            <span class="inline-flex size-9 items-center justify-center rounded-md bg-accent/10 text-accent">
                <Icon Name="mail" Class="size-4" />
            </span>
        </div>
        <div class="mt-3 font-display text-3xl font-semibold tracking-tight">@_subscribers</div>
    </div>
</div>

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mt-6">
    <a href="/admin/manage-posts/new" class="group bg-base-100 border border-base-300 rounded-box p-6 hover:border-primary/60 transition-colors">
        <div class="flex items-center gap-3">
            <span class="inline-flex size-10 items-center justify-center rounded-md bg-primary text-primary-content">
                <Icon Name="plus" Class="size-5" />
            </span>
            <div>
                <div class="font-semibold">New post</div>
                <div class="text-xs text-base-content/60">Write a new article</div>
            </div>
        </div>
    </a>
    <a href="/admin/manage-categories" class="group bg-base-100 border border-base-300 rounded-box p-6 hover:border-primary/60 transition-colors">
        <div class="flex items-center gap-3">
            <span class="inline-flex size-10 items-center justify-center rounded-md bg-base-200 text-base-content">
                <Icon Name="tag" Class="size-5" />
            </span>
            <div>
                <div class="font-semibold">Manage categories</div>
                <div class="text-xs text-base-content/60">Organize your content</div>
            </div>
        </div>
    </a>
    <a href="/admin/manage-subscribers" class="group bg-base-100 border border-base-300 rounded-box p-6 hover:border-primary/60 transition-colors">
        <div class="flex items-center gap-3">
            <span class="inline-flex size-10 items-center justify-center rounded-md bg-base-200 text-base-content">
                <Icon Name="mail" Class="size-5" />
            </span>
            <div>
                <div class="font-semibold">Subscribers</div>
                <div class="text-xs text-base-content/60">See who follows you</div>
            </div>
        </div>
    </a>
</div>

@code {
    private int _posts;
    private int _categories;
    private int _subscribers;

    protected override async Task OnInitializedAsync()
    {
        var postsTask = BlogPostAdminService.GetBlogPostsAsync(0, 1);
        var categoriesTask = CategoryService.GetCategoriesAsync();
        var subscribersTask = SubscriberService.GetSubscribersAsync(0, 1);

        await Task.WhenAll(postsTask, categoriesTask, subscribersTask);

        _posts = postsTask.Result.TotalCount;
        _categories = categoriesTask.Result.Count;
        _subscribers = subscribersTask.Result.TotalCount;
    }
}
