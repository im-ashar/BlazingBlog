@page "/admin/manage-categories"
@using BlazingBlog.Components.Shared
@using BlazingBlog.Data.Models
@rendermode @(new InteractiveServerRenderMode(prerender:false))

<PageTitle>Categories · Admin</PageTitle>

<AdminHeader Title="Categories" Subtitle="Organize posts into topics.">
    <ActionButtons>
        <button type="button" class="btn btn-primary btn-sm gap-1" @onclick="HandleNewCategory">
            <Icon Name="plus" Class="size-4" />
            <span class="hidden sm:inline">New category</span>
        </button>
    </ActionButtons>
</AdminHeader>

<div class="bg-base-100 border border-base-300 rounded-box overflow-hidden">
    <div class="overflow-x-auto">
        <table class="table table-zebra w-full">
            <thead>
                <tr>
                    <th class="w-16">ID</th>
                    <th>Name</th>
                    <th>Slug</th>
                    <th>Show on navbar</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (categories is null || !categories.Any())
                {
                    <tr><td colspan="5" class="text-center text-base-content/60 py-8">No categories yet.</td></tr>
                }
                else
                {
                    @foreach (var cat in categories)
                    {
                        <tr>
                            <td class="font-mono text-xs">@cat.Id</td>
                            <td class="font-medium">@cat.Name</td>
                            <td><span class="text-xs text-base-content/60 font-mono">@cat.Slug</span></td>
                            <td>
                                <input type="checkbox" class="toggle toggle-primary toggle-sm" checked="@cat.ShowOnNavbar" @onchange="@(() => HandleShowOnNavbarAsync(cat))" />
                            </td>
                            <td>
                                <div class="flex items-center justify-end gap-1">
                                    <button type="button" class="btn btn-ghost btn-xs gap-1" @onclick="() => HandleEditCategory(cat)">
                                        <Icon Name="pencil" Class="size-4" /> <span class="hidden sm:inline">Edit</span>
                                    </button>
                                    <button type="button" class="btn btn-ghost btn-xs text-error gap-1" @onclick="() => DeleteCategoryAsync(cat)">
                                        <Icon Name="trash" Class="size-4" /> <span class="hidden sm:inline">Delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<dialog id="category-modal" class="modal">
    <div class="modal-box max-w-md">
        <h3 class="font-display text-xl font-semibold tracking-tight">@_modalTitle</h3>

        @if (selectedCategory is not null)
        {
            <EditForm Model="selectedCategory" OnValidSubmit="SaveCategoryAsync" class="mt-4 space-y-4">
                <DataAnnotationsValidator />
                <div class="form-control">
                    <label class="label pb-1"><span class="label-text text-sm font-medium">Category name</span></label>
                    <InputText @bind-Value="selectedCategory!.Name" class="input input-bordered w-full bg-base-100" placeholder="e.g. Blazor" />
                    <ValidationMessage For="() => selectedCategory.Name" class="text-error text-xs mt-1" />
                </div>
                <label class="flex items-center gap-3 cursor-pointer">
                    <InputCheckbox @bind-Value="selectedCategory.ShowOnNavbar" class="toggle toggle-primary toggle-sm" />
                    <span class="text-sm">Show in main navigation</span>
                </label>

                <div class="modal-action">
                    <button type="button" class="btn btn-ghost" @onclick="() => HandleModal(false)">Cancel</button>
                    <button type="submit" class="btn btn-primary gap-1">
                        <Icon Name="save" Class="size-4" /> Save
                    </button>
                </div>
            </EditForm>
        }
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

@code {
    private string _modalTitle = "New category";
}
