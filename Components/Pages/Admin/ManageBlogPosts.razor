@page "/admin/manage-posts"
@using BlazingBlog.Components.Shared
@using BlazingBlog.Data.Models
@rendermode @(new InteractiveServerRenderMode(prerender:false))
@inject IBlogPostAdminService BlogPostAdminService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ToastService ToastService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Manage Posts · Admin</PageTitle>

<AdminHeader Title="Posts" Subtitle="Create, edit and delete blog posts.">
    <ActionButtons>
        <div class="join">
            <input type="search" placeholder="Search posts..."
                   class="input input-bordered input-sm join-item w-44 sm:w-64"
                   value="@_search"
                   @oninput="HandleSearchInput" />
            <button type="button" class="btn btn-sm btn-ghost join-item" aria-label="Search">
                <Icon Name="search" Class="size-4" />
            </button>
        </div>
        <a href="/admin/manage-posts/new" class="btn btn-primary btn-sm gap-1">
            <Icon Name="plus" Class="size-4" />
            <span class="hidden sm:inline">New post</span>
        </a>
    </ActionButtons>
</AdminHeader>

<div class="bg-base-100 border border-base-300 rounded-box overflow-hidden">
    @if (_isEmpty)
    {
        <div class="flex flex-col items-center justify-center py-16 px-6 text-center">
            <span class="inline-flex size-12 items-center justify-center rounded-full bg-base-200 text-base-content/60 mb-4">
                <Icon Name="file-text" Class="size-6" />
            </span>
            <h3 class="font-display text-lg font-semibold tracking-tight mb-1">@(string.IsNullOrWhiteSpace(_search) ? "No posts yet" : "No results")</h3>
            <p class="text-sm text-base-content/60 max-w-sm mb-4">
                @(string.IsNullOrWhiteSpace(_search)
                    ? "Write your first blog post and it'll show up here."
                    : $"No posts matched \"{_search}\". Try a different search.")
            </p>
            @if (string.IsNullOrWhiteSpace(_search))
            {
                <a href="/admin/manage-posts/new" class="btn btn-primary btn-sm gap-1">
                    <Icon Name="plus" Class="size-4" /> New post
                </a>
            }
        </div>
    }
    <div class="overflow-x-auto @(_isEmpty ? "hidden" : "")">
        <QuickGrid ItemsProvider="_postsProvider" Pagination="_pagination" Class="table table-zebra w-full" @ref="_grid">
            <TemplateColumn Title="Post" SortBy="@_titleSort">
                <div class="flex items-center gap-3 py-2">
                    <img src="@context.Image" class="size-12 rounded-md object-cover border border-base-300 bg-base-200 shrink-0" alt="" />
                    <div class="min-w-0">
                        <div class="font-medium truncate">@context.Title</div>
                        @if (context.IsPublished)
                        {
                            <a href="/posts/@context.Slug" target="_blank" class="text-xs text-primary hover:underline truncate block">@context.Slug</a>
                        }
                        else
                        {
                            <span class="text-xs text-base-content/50 truncate block">@context.Slug</span>
                        }
                    </div>
                </div>
            </TemplateColumn>
            <TemplateColumn Title="Category">
                <span class="badge badge-ghost">@context.Category?.Name</span>
            </TemplateColumn>
            <TemplateColumn Title="Featured">
                <input type="checkbox" class="toggle toggle-primary toggle-sm" checked="@context.IsFeatured" @onchange="@(() => HandleIsFeaturedAsync(context))" />
            </TemplateColumn>
            <TemplateColumn Title="Published">
                <input type="checkbox" class="toggle toggle-success toggle-sm" checked="@context.IsPublished" @onchange="@(() => HandleIsPublishedAsync(context))" />
            </TemplateColumn>
            <TemplateColumn Title="Actions" Align="Align.End">
                <div class="flex items-center justify-end gap-1">
                    <a href="/admin/manage-posts/edit/@context.Id" class="btn btn-ghost btn-xs gap-1" title="Edit">
                        <Icon Name="pencil" Class="size-4" /> <span class="hidden sm:inline">Edit</span>
                    </a>
                    <button type="button" class="btn btn-ghost btn-xs text-error gap-1" title="Delete" @onclick="() => OpenDeleteDialog(context)">
                        <Icon Name="trash" Class="size-4" /> <span class="hidden sm:inline">Delete</span>
                    </button>
                </div>
            </TemplateColumn>
        </QuickGrid>
    </div>
    <div class="border-t border-base-300 p-3 flex items-center justify-end @(_isEmpty ? "hidden" : "")">
        <Paginator State="_pagination" />
    </div>
</div>

<dialog id="delete-post-modal" class="modal">
    <div class="modal-box max-w-lg">
        <h3 class="font-display text-xl font-semibold tracking-tight">Delete blog post?</h3>
        <p class="text-sm text-base-content/70 mt-1">This action cannot be undone.</p>

        @if (_selectedBlogPost is not null)
        {
            <dl class="mt-5 bg-base-200 rounded-box p-4 text-sm space-y-1.5">
                <div class="flex gap-2"><dt class="font-semibold w-20">ID:</dt><dd>@_selectedBlogPost.Id</dd></div>
                <div class="flex gap-2"><dt class="font-semibold w-20">Title:</dt><dd class="truncate">@_selectedBlogPost.Title</dd></div>
                <div class="flex gap-2"><dt class="font-semibold w-20">Slug:</dt><dd class="truncate">@_selectedBlogPost.Slug</dd></div>
                <div class="flex gap-2"><dt class="font-semibold w-20">Category:</dt><dd>@_selectedBlogPost.Category?.Name</dd></div>
            </dl>
        }

        <div class="modal-action">
            <button type="button" class="btn btn-ghost" @onclick="CloseDeleteDialog">Cancel</button>
            <button type="button" class="btn btn-error gap-1" @onclick="ConfirmDeleteAsync">
                <Icon Name="trash" Class="size-4" /> Delete
            </button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

@code {
    private const int PageSize = 10;
    private QuickGrid<BlogPost>? _grid;
    private PaginationState _pagination = new() { ItemsPerPage = PageSize };
    private GridItemsProvider<BlogPost> _postsProvider = default!;
    private GridSort<BlogPost> _titleSort = GridSort<BlogPost>.ByAscending(p => p.Title);
    private BlogPost? _selectedBlogPost;
    private string _search = string.Empty;
    private CancellationTokenSource? _searchCts;
    private bool _isEmpty;

    protected override void OnInitialized()
    {
        _postsProvider = async request =>
        {
            var sortField = request.SortByColumn?.Title switch
            {
                "Post" => nameof(BlogPost.Title),
                "Category" => nameof(BlogPost.Category),
                "Featured" => nameof(BlogPost.IsFeatured),
                "Published" => nameof(BlogPost.IsPublished),
                _ => nameof(BlogPost.Id)
            };
            var result = await BlogPostAdminService.GetBlogPostsAsync(
                request.StartIndex,
                request.Count ?? PageSize,
                _search,
                sortField,
                !request.SortByAscending,
                request.CancellationToken);
            _isEmpty = result.TotalCount == 0;
            return GridItemsProviderResult.From(result.Items, result.TotalCount);
        };
    }

    private async Task HandleSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? string.Empty;
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(300, _searchCts.Token);
            if (_grid is not null)
                await _grid.RefreshDataAsync();
        }
        catch (TaskCanceledException) { }
    }

    private async Task HandleIsFeaturedAsync(BlogPost blogPost)
    {
        try
        {
            var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            blogPost.IsFeatured = !blogPost.IsFeatured;
            await BlogPostAdminService.SaveBlogPostAsync(blogPost, auth.User.GetIdOfUser());
        }
        catch (Exception ex)
        {
            ex.ShowErrorToast(ToastService);
        }
    }

    private async Task HandleIsPublishedAsync(BlogPost blogPost)
    {
        try
        {
            var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            blogPost.IsPublished = !blogPost.IsPublished;
            await BlogPostAdminService.SaveBlogPostAsync(blogPost, auth.User.GetIdOfUser());
        }
        catch (Exception ex)
        {
            ex.ShowErrorToast(ToastService);
        }
    }

    private async Task OpenDeleteDialog(BlogPost blogPost)
    {
        _selectedBlogPost = blogPost;
        await JS.InvokeVoidAsync("BlazingBlogModal.show", "delete-post-modal");
    }

    private async Task CloseDeleteDialog()
    {
        _selectedBlogPost = null;
        await JS.InvokeVoidAsync("BlazingBlogModal.close", "delete-post-modal");
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_selectedBlogPost is null) return;
        try
        {
            var result = await BlogPostAdminService.DeleteBlogPostAsync(_selectedBlogPost.Id);
            if (result != null)
            {
                ToastService.ShowSuccessToast("Blog post deleted.");
            }
        }
        catch (Exception ex)
        {
            ex.ShowErrorToast(ToastService);
        }
        finally
        {
            await CloseDeleteDialog();
            if (_grid is not null)
                await _grid.RefreshDataAsync();
        }
    }
}
