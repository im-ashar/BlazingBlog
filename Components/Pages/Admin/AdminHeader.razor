<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
        <h1 class="font-display text-2xl sm:text-3xl font-semibold tracking-tight">@Title</h1>
        @if (!string.IsNullOrEmpty(Subtitle))
        {
            <p class="text-sm text-base-content/60 mt-1">@Subtitle</p>
        }
    </div>
    @if (ActionButtons is not null)
    {
        <div class="flex items-center gap-2">
            @ActionButtons
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = default!;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public RenderFragment? ActionButtons { get; set; }
}
