@using BlazingBlog.Data.Models

<aside class="lg:sticky lg:top-24 h-fit">
    <div class="flex items-center gap-2 mb-4">
        <span class="inline-block w-1 h-5 bg-primary rounded-full"></span>
        <h2 class="font-display text-base font-semibold uppercase tracking-wider">Popular</h2>
    </div>
    <ol class="bg-base-100 border border-base-300 rounded-box divide-y divide-base-300">
        @{ var rank = 0; }
        @foreach (var post in Posts)
        {
            rank++;
            <li class="p-4">
                <div class="flex gap-3">
                    <span class="font-display text-2xl font-bold text-base-content/20 leading-none w-8 shrink-0">@rank.ToString("00")</span>
                    <div class="min-w-0">
                        <a href="/posts/@post.Slug" class="font-medium text-sm leading-snug line-clamp-2 hover:text-primary transition-colors">@post.Title</a>
                        <div class="mt-1 text-xs text-base-content/60">
                            @post.User?.FullName
                            @if (post.Category is not null)
                            {
                                <text> in </text>
                                <a href="@(post.Category.Slug + "-posts")" class="text-primary hover:underline">@post.Category.Name</a>
                            }
                        </div>
                    </div>
                </div>
            </li>
        }
    </ol>
</aside>

@code {
    [Parameter, EditorRequired]
    public BlogPost[] Posts { get; set; } = [];
}
