@inject NavigationManager NavigationManager
@using BlazingBlog.Components.Shared

<form action="Account/Logout" method="post" class="w-full">
    <AntiforgeryToken />
    <input type="hidden" name="ReturnUrl" value="@currentUrl" />
    <button type="submit"
            class="flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium text-base-content/70 hover:bg-error/10 hover:text-error transition-colors w-full">
        <Icon Name="log-out" Class="size-4" />
        Logout
    </button>
</form>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.BaseUri);
    }
}
