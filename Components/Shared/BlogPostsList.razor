@using BlazingBlog.Data.Models
@using BlazingBlog.Utilities

<div class="grid gap-6 sm:grid-cols-2">
    @foreach (var post in Posts)
    {
        <a href="/posts/@post.Slug"
           class="group flex flex-col bg-base-100 border border-base-300 rounded-box overflow-hidden hover:border-primary/60 hover:-translate-y-0.5 transition-all duration-200">
            <div class="aspect-[16/10] bg-base-200 overflow-hidden">
                <img src="@post.Image"
                     alt="@post.Title"
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                     loading="lazy" />
            </div>
            <div class="flex flex-col flex-1 p-5">
                @if (post.Category is not null)
                {
                    <a href="@(post.Category.Slug + "-posts")"
                       class="self-start text-[11px] font-semibold uppercase tracking-wider text-primary mb-2 hover:underline">
                        @post.Category.Name
                    </a>
                }
                <h3 class="font-display text-lg font-semibold leading-snug tracking-tight mb-2 group-hover:text-primary transition-colors">
                    @post.Title
                </h3>
                <p class="text-sm text-base-content/70 line-clamp-2 mb-4">
                    @post.Introduction
                </p>
                <div class="mt-auto flex items-center justify-between text-xs text-base-content/60">
                    <span>@post.User?.FullName</span>
                    <span>@post.PublishedAt.ToDisplay()</span>
                </div>
            </div>
        </a>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public BlogPost[] Posts { get; set; } = [];
}
